# Database (Vercel Postgres/Supabase)
DATABASE_URL="postgresql://user:password@host:5432/edbridge"

# JWT Secret (openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-here"

# Email (Gmail App Password)
