generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  role          Role          @default(CLIENT)
  phone         String?
  organisation  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  consultations Consultation[]
  downloads     Download[]
}

model Consultation {
  id          String             @id @default(cuid())
  userId      String?
  name        String
  email       String
  phone       String?
  service     String
  founder     String
  date        DateTime
  timeSlot    String
  message     String?
  status      ConsultationStatus @default(PENDING)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User?              @relation(fields: [userId], references: [id])
}

model FileResource {
  id          String     @id @default(cuid())
  title       String
  description String?
  category    FileCategory
  fileUrl     String
  fileSize    String?
  isPublic    Boolean    @default(false)
  uploadedAt  DateTime   @default(now())
  downloads   Download[]
}

model Download {
  id        String       @id @default(cuid())
  userId    String
  fileId    String
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id])
  file      FileResource @relation(fields: [fileId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  CLIENT
  ADMIN
}

enum ConsultationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum FileCategory {
  CURRICULUM_GUIDE
  SCHOOL_CHECKLIST
  APPLICATION_FORM
  UNIVERSITY_GUIDE
  TRAINING_MATERIAL
  GENERAL
}
